@charset "utf-8";

* { box-sizing: border-box; }

body { background-color: rgb(226, 209, 179); font-family: Lora, serif; marg=
in: 0px; padding: 0px; color: rgb(34, 34, 34); line-height: 1.6; }

header { width: 100%; background-image: url("logo.jpg"); background-size: c=
over; background-position: center center; background-repeat: no-repeat; pad=
ding: 100px 20px; text-align: center; border-bottom: 5px solid rgb(184, 134=
, 11); }

header h1 { color: rgb(255, 255, 255); text-shadow: rgba(0, 0, 0, 0.8) 3px =
3px 10px; font-size: clamp(1.5rem, 6vw, 3rem); margin-bottom: 20px; }

header h1 { color: rgb(255, 255, 255); font-size: clamp(1.5rem, 5vw, 2.5rem=
); text-transform: uppercase; margin: 0px 0px 20px; letter-spacing: 2px; }

nav ul { list-style: none; padding: 0px; margin: 0px; display: flex; gap: 1=
5px; flex-wrap: wrap; justify-content: center; }

nav a { color: white; text-decoration: none; font-weight: bold; font-size: =
0.8rem; text-transform: uppercase; padding: 6px 12px; background: rgba(255,=
 255, 255, 0.1); border-radius: 5px; transition: 0.3s; white-space: nowrap;=
 }

nav a:hover { background: rgb(184, 134, 11); color: white; }

main { max-width: 800px; margin: 40px auto; padding: 0px 20px; text-align: =
center; }

.foto-perfil { width: 250px; height: 250px; object-fit: cover; object-posit=
ion: center top; border: 5px solid white; box-shadow: rgba(0, 0, 0, 0.2) 0p=
x 5px 15px; border-radius: 15px; margin-bottom: 20px; }

.bienvenida h2 { color: rgb(0, 51, 102); margin-top: 0px; }

@media (max-width: 600px) {
  header { padding: 25px 10px; }
  .foto-perfil { width: 200px; height: 200px; }
}
